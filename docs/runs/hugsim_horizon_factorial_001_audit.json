  "diagnostic_findings": {
    "finite_rollout_tail_padding": {
      "component": "metric_implementation",
      "expected": "A metric frame without all required future actor states should be marked invalid rather than scored with fabricated future states.",
      "observed": "The short-run scorer silently repeats its final actor box and emits TTC/NC failures; those failures disappear when the exact prefix is evaluated with complete future actor history.",
      "expectation_met": false,
      "evidence_decision": "accepted",
      "implication": "NC/TTC events require a complete-future-history gate; tail-padded events cannot support driving-risk conclusions.",
      "evidence_refs": [
        "artifacts/hugsim_contrast/scene-0383-horizon-factorial-report-run002/horizon_factorial_summary.json",
        "artifacts/hugsim_contrast/scene-0383-horizon-factorial-report-run002/horizon_sensitivity_and_clearance.png"
      ]
    },
    "far_cut_in_is_nonrisk_control": {
      "component": "scenario_geometry",
      "expected": "The extended far cut-in should remain non-colliding when evaluated with complete actor history.",
      "observed": "NC/TTC/PDMS remain 1.0 in the valid window and minimum 2D footprint clearance is about 4.195 m.",
      "expectation_met": true,
      "evidence_decision": "accepted",
      "implication": "Centerline crossing alone is insufficient to define a risk event; the far cut-in is a negative control.",
      "evidence_refs": [
        "artifacts/hugsim_contrast/scene-0383-horizon-factorial-report-run002/horizon_factorial_summary.json"
      ]
    },
    "reset_advances_actor_before_first_record": {
      "component": "actor_timing",
      "expected": "The timestamp-zero actor state should equal the configured YAML initial state.",
      "observed": "The environment advances ConstantPlanner once during reset before recording the timestamp-zero state.",
      "expectation_met": false,
      "evidence_decision": "accepted",
      "implication": "Exact actor-time provenance has a one-update phase offset and must use recorded states rather than assuming YAML state at t=0.",
      "evidence_refs": [
        "artifacts/hugsim_contrast/scene-0383-multicar-cut-in-00-run002-9s/audit_summary.json",
        "docs/runs/hugsim_multicar_cut_in_001.md"
      ]
    }
